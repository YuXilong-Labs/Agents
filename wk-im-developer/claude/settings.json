{
  "permissions": {
    "allow": [
      "Bash(xcodebuild*)",
      "Bash(pod install*)",
      "Bash(pod lib lint*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git log*)",
      "Bash(git blame*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(ls*)",
      "Bash(bash scripts/*)",
      "Bash(bash ~/.wk-im-developer/scripts/*)",
      "Bash(source ~/.wk-im-developer/config*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 claude/hooks/scope-check.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.wk-im-developer/scripts/guard.sh --quiet 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
