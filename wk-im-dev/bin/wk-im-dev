#!/bin/bash
# wk-im-dev - Unified launcher for the wk-im-dev IM component agent.
#
# Usage:
#   wk-im-dev                      # auto-detect: Claude Code (if plugin installed) else Codex
#   wk-im-dev [codex/claude opts] [prompt]
#   wk-im-dev doctor               # show install status
#   wk-im-dev doctor --fix         # also print copy-paste fix commands
#   wk-im-dev --version            # print version + source
#   wk-im-dev --help               # this help
#
# Runtime selection precedence:
#   1. $WK_IM_DEV_RUNTIME=claude|codex (env override)
#   2. claude CLI present AND wk-im-dev plugin enabled in ~/.claude/settings.json
#   3. Otherwise Codex
#
# Created by yuxilong on 2026-05-26

set -euo pipefail

CORE_SPEC="${WK_IM_DEV_CORE:-$HOME/.wk-im-dev/wk-im-dev-core.md}"
SELF="$0"

show_help() {
  sed -n '2,18p' "$SELF" | sed 's/^# \{0,1\}//'
}

# ----- version lookup ------------------------------------------------------
# 从 plugin.json 读 version。优先级：
#   1. $WK_IM_DEV_PLUGIN_JSON 环境变量
#   2. Codex 安装路径 (~/.wk-im-dev/.claude-plugin/plugin.json) — installer 顺手 copy
#   3. Claude plugin 安装位置 (~/.claude/plugins/installed/wk-im-dev*/.claude-plugin/plugin.json)
#   4. 当前仓库源码位置（开发场景）
#   5. 退而求其次：返回 unknown
read_version() {
  local file v

  try_read() {
    local f="$1"
    [ -f "$f" ] || return 1
    v="$(grep -oE '"version"[[:space:]]*:[[:space:]]*"[^"]+"' "$f" 2>/dev/null \
         | head -1 | sed -E 's/.*"([^"]+)"$/\1/')"
    [ -n "$v" ] || return 1
    printf '%s\t%s\n' "$v" "$f"
    return 0
  }

  # 1. 环境变量
  if [ -n "${WK_IM_DEV_PLUGIN_JSON:-}" ]; then
    try_read "$WK_IM_DEV_PLUGIN_JSON" && return 0
  fi

  # 2. Codex 安装路径
  try_read "$HOME/.wk-im-dev/.claude-plugin/plugin.json" && return 0

  # 3. Claude plugin 安装路径（用 ls -1 避免空 glob 在 set -u 下出问题）
  for f in $(ls -1 "$HOME"/.claude/plugins/installed/wk-im-dev*/.claude-plugin/plugin.json 2>/dev/null) \
           $(ls -1 "$HOME"/.claude/plugins/cache/*/wk-im-dev*/.claude-plugin/plugin.json 2>/dev/null); do
    try_read "$f" && return 0
  done

  # 4. 开发场景：launcher 自身相对位置
  local self_dir
  self_dir="$(cd "$(dirname "$SELF")" 2>/dev/null && pwd)" || true
  if [ -n "$self_dir" ]; then
    try_read "$self_dir/../.claude-plugin/plugin.json" && return 0
  fi

  printf 'unknown\t<not found>\n'
}

show_version() {
  local out version source
  out="$(read_version)"
  version="${out%%	*}"
  source="${out#*	}"
  echo "wk-im-dev $version"
  echo "  source: $source"
}

# ----- runtime detection --------------------------------------------------

claude_plugin_installed() {
  command -v claude >/dev/null 2>&1 || return 1
  local settings="$HOME/.claude/settings.json"
  # Claude writes the plugin key as either:
  #   "wk-im-dev": true                       (older / scoped form)
  #   "wk-im-dev@<marketplace>": true         (current form, e.g. wk-im-dev@yuxilong-agents)
  # Accept both via an extended regex.
  if [ -f "$settings" ] && grep -qE '"wk-im-dev(@[A-Za-z0-9._-]+)?"' "$settings" 2>/dev/null; then
    return 0
  fi
  # Also accept a local --plugin-dir style: a plugin source directory under PWD
  if [ -d "./.claude-plugin" ] && [ -f "./.claude-plugin/plugin.json" ] \
     && grep -q '"wk-im-dev"' "./.claude-plugin/plugin.json" 2>/dev/null; then
    return 0
  fi
  return 1
}

codex_available() {
  command -v codex >/dev/null 2>&1
}

detect_runtime() {
  case "${WK_IM_DEV_RUNTIME:-}" in
    claude|codex) printf '%s\n' "$WK_IM_DEV_RUNTIME"; return ;;
    "") ;;
    *) echo "warn: ignoring unknown WK_IM_DEV_RUNTIME=$WK_IM_DEV_RUNTIME" >&2 ;;
  esac
  if claude_plugin_installed; then
    printf 'claude\n'
  elif codex_available; then
    printf 'codex\n'
  else
    printf 'none\n'
  fi
}

# ----- doctor -------------------------------------------------------------

ok()   { printf '  [ok]   %s\n' "$1"; }
miss() { printf '  [miss] %s\n' "$1"; }
warn() { printf '  [warn] %s\n' "$1"; }

doctor_line_file() {
  local label="$1"; local path="$2"
  if [ -f "$path" ]; then ok "$label: $path"; else miss "$label: $path"; fi
}

doctor_line_dir() {
  local label="$1"; local path="$2"
  if [ -d "$path" ]; then ok "$label: $path"; else miss "$label: $path"; fi
}

run_doctor() {
  local vout vversion vsource
  local fix_mode=0
  if [ "${1:-}" = "--fix" ]; then fix_mode=1; fi

  FIXES=()
  add_fix() { FIXES+=("$1"); }

  vout="$(read_version)"
  vversion="${vout%%	*}"
  vsource="${vout#*	}"
  echo "wk-im-dev doctor"
  echo "  version: $vversion ($vsource)"
  echo ""
  echo "Runtime detection:"
  echo "  WK_IM_DEV_RUNTIME=${WK_IM_DEV_RUNTIME:-<unset>}"
  if command -v claude >/dev/null 2>&1; then
    ok "claude CLI: $(command -v claude)"
  else
    miss "claude CLI not on PATH"
    add_fix "# 安装 Claude Code: https://claude.com/claude-code"
  fi
  if command -v codex  >/dev/null 2>&1; then
    ok "codex CLI:  $(command -v codex)"
  else
    miss "codex CLI not on PATH"
    add_fix "# 安装 Codex CLI: https://github.com/openai/codex"
  fi
  if claude_plugin_installed; then
    ok "Claude plugin wk-im-dev enabled"
  else
    miss "Claude plugin wk-im-dev not enabled"
    if command -v claude >/dev/null 2>&1; then
      add_fix "claude plugin marketplace add YuXilong-Labs/Agents"
      add_fix "claude plugin install wk-im-dev@yuxilong-agents"
    fi
  fi
  echo "  effective runtime: $(detect_runtime)"
  echo ""

  echo "Install artifacts:"
  doctor_line_file "launcher"   "$HOME/.wk-im-dev/bin/wk-im-dev"
  doctor_line_file "core spec"  "$CORE_SPEC"
  doctor_line_dir  "bin dir"    "$HOME/.wk-im-dev/bin"
  doctor_line_file "init.sh"    "$HOME/.wk-im-dev/bin/wk-im-init.sh"
  doctor_line_file "codex agent" "$HOME/.codex/agents/wk-im-dev.toml"
  if [ ! -f "$HOME/.wk-im-dev/bin/wk-im-dev" ]; then
    add_fix "# 重装 launcher（命中本机源码时）："
    add_fix "curl -fsSL https://raw.githubusercontent.com/YuXilong-Labs/Agents/main/wk-im-dev/scripts/bootstrap.sh | bash -s -- --target ."
  fi
  if [ -f "${CODEX_HOME:-$HOME/.codex}/config.toml" ] \
     && grep -q '^\[profiles\.wk-im-dev\]' "${CODEX_HOME:-$HOME/.codex}/config.toml" 2>/dev/null; then
    ok "codex profile [profiles.wk-im-dev] present"
  else
    miss "codex profile [profiles.wk-im-dev] missing"
    if command -v codex >/dev/null 2>&1; then
      add_fix "# Codex profile 未写入。先确保 ~/.codex/config.toml 存在（codex 启动过一次会自动创建），然后重跑 install.sh："
      add_fix "curl -fsSL https://raw.githubusercontent.com/YuXilong-Labs/Agents/main/wk-im-dev/scripts/bootstrap.sh | bash -s -- --target . --runtime codex"
    fi
  fi
  echo ""

  echo "Workspace:"
  local ws="$HOME/.wk-im-dev/workspace.json"
  if [ -f "$ws" ]; then
    ok "workspace.json: $ws"
    sed 's/^/      /' "$ws"
  else
    miss "workspace.json (run: wk-im-init.sh)"
    add_fix "# 在 BTIMService/BTIMModule/HostApp 任一仓库内运行："
    add_fix "$HOME/.wk-im-dev/bin/wk-im-init.sh"
  fi
  echo ""

  echo "PATH:"
  case ":$PATH:" in
    *":$HOME/.wk-im-dev/bin:"*) ok "~/.wk-im-dev/bin on PATH" ;;
    *)
      warn "~/.wk-im-dev/bin NOT on PATH"
      add_fix "export PATH=\"\$HOME/.wk-im-dev/bin:\$PATH\""
      add_fix "# 永久生效：把上面这一行追加到 ~/.zshrc 或 ~/.bashrc"
      ;;
  esac
  echo ""

  echo "CodeGraph (optional):"
  local cg="$HOME/.wk-im-dev/bin/wk-im-codegraph.sh"
  if [ -x "$cg" ] && "$cg" detect --quiet >/dev/null 2>&1; then
    ok "codegraph installed"
  else
    warn "codegraph not installed (optional)"
    if [ -x "$cg" ]; then
      add_fix "# 启用 CodeGraph（可选，提升符号检索效率）："
      add_fix "$cg install && $cg init --root <BTIMService_or_BTIMModule>"
    fi
  fi

  # 总结：列出建议的修复命令；--fix 仅打印，不主动执行（安全优先）
  if [ "${#FIXES[@]}" -gt 0 ]; then
    echo ""
    echo "Suggested fixes:"
    for line in "${FIXES[@]}"; do
      case "$line" in
        \#*) echo "  $line" ;;
        *)   echo "    $line" ;;
      esac
    done
    if [ "$fix_mode" -eq 1 ]; then
      echo ""
      echo "（--fix 仅打印命令，不自动执行；复制需要的一行粘贴运行即可。）"
    fi
  else
    echo ""
    echo "✓ 所有检查通过，无需修复。"
  fi
}

# ----- claude dispatch ----------------------------------------------------

launch_claude() {
  exec claude --agent wk-im-dev "$@"
}

# ----- codex dispatch (preserves original behavior) -----------------------

launch_codex() {
  if [ ! -f "$CORE_SPEC" ]; then
    cat >&2 <<ERR
wk-im-dev: core spec not found at $CORE_SPEC
Re-run the installer to fix this:
  curl -fsSL https://raw.githubusercontent.com/YuXilong-Labs/Agents/main/wk-im-dev/scripts/bootstrap.sh \\
    | bash -s -- --target .
ERR
    exit 1
  fi

  local args=(-c "developer_instructions=$(cat "$CORE_SPEC")")
  local codex_cfg="${CODEX_HOME:-$HOME/.codex}/config.toml"
  if grep -q '^\[profiles\.wk-im-dev\]' "$codex_cfg" 2>/dev/null; then
    args+=(--profile wk-im-dev)
  else
    # 没装 profile 时只覆盖 reasoning_effort，model 走 Codex 默认，避免模型权限问题
    args+=(-c model_reasoning_effort='"high"')
  fi
  exec codex "${args[@]}" "$@"
}

# ----- main ---------------------------------------------------------------

# Recognize the doctor subcommand or --doctor flag before we forward args.
if [ $# -ge 1 ]; then
  case "$1" in
    doctor|--doctor)       shift; run_doctor "$@"; exit 0 ;;
    version|--version|-V)  show_version; exit 0 ;;
    -h|--help)             show_help; exit 0 ;;
  esac
fi

RUNTIME="$(detect_runtime)"
case "$RUNTIME" in
  claude) launch_claude "$@" ;;
  codex)  launch_codex  "$@" ;;
  none)
    cat >&2 <<ERR
wk-im-dev: no supported runtime found.
Install one of:
  - Claude Code: claude plugin install wk-im-dev@yuxilong-agents
  - Codex CLI:   https://github.com/openai/codex
Then run: wk-im-dev doctor
ERR
    exit 1
    ;;
esac
